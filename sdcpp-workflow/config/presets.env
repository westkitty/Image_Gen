# BigMac SDCPP speed/quality presets (SD 1.5 @ 512x512 unless noted).
# Sourced by sdcpp-lib.sh (load_presets) and resolved by apply_preset <name>.
# Explicit CLI flags ALWAYS override preset values.
#
# Preset names: smoke | thumbnail | fast | balanced | quality | quality_plus
# Each defines WIDTH / HEIGHT / STEPS / CFG_SCALE / SAMPLER.

# smoke: fastest proof gate
PRESET_SMOKE_WIDTH=512
PRESET_SMOKE_HEIGHT=512
PRESET_SMOKE_STEPS=1
PRESET_SMOKE_CFG_SCALE=7.0
PRESET_SMOKE_SAMPLER=euler_a

# thumbnail: tiny quick visual sanity
PRESET_THUMB_WIDTH=384
PRESET_THUMB_HEIGHT=384
PRESET_THUMB_STEPS=4
PRESET_THUMB_CFG_SCALE=7.0
PRESET_THUMB_SAMPLER=euler_a

# fast: day-to-day quick generation
PRESET_FAST_WIDTH=512
PRESET_FAST_HEIGHT=512
PRESET_FAST_STEPS=8
PRESET_FAST_CFG_SCALE=7.0
PRESET_FAST_SAMPLER=euler_a

# balanced: usable image without waiting forever
PRESET_BALANCED_WIDTH=512
PRESET_BALANCED_HEIGHT=512
PRESET_BALANCED_STEPS=16
PRESET_BALANCED_CFG_SCALE=7.0
PRESET_BALANCED_SAMPLER=euler_a

# quality: current SD 1.5 normal-step target
PRESET_QUALITY_WIDTH=512
PRESET_QUALITY_HEIGHT=512
PRESET_QUALITY_STEPS=20
PRESET_QUALITY_CFG_SCALE=7.0
PRESET_QUALITY_SAMPLER=euler_a

# quality_plus: slower comparison point
PRESET_QUALITY_PLUS_WIDTH=512
PRESET_QUALITY_PLUS_HEIGHT=512
PRESET_QUALITY_PLUS_STEPS=30
PRESET_QUALITY_PLUS_CFG_SCALE=7.0
PRESET_QUALITY_PLUS_SAMPLER=euler_a
